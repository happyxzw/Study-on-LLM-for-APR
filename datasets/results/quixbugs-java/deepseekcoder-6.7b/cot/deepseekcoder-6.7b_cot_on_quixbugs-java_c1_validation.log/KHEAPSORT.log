                public static ArrayList<Integer> kheapsort(ArrayList<Integer> arr, int k) {
    PriorityQueue<Integer> heap = new PriorityQueue<Integer>();
    //only need to iterate through the first k elements
    for (Integer v : arr.subList(0,k)) {
        heap.add(v);
    }
    ArrayList<Integer> output = new ArrayList<Integer>();
    //need to iterate through the first k elements
    for (Integer x : arr) {
        heap.add(x);
                Integer popped = heap.poll();
        output.add(popped);
    }
    //when there is more elements in the heap, we need to add them to the output arraylist
    while (!heap.isEmpty()) {
        output.add(heap.poll());
    }
    return output;
}

