                PATCH:
                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    for (int i=perm.size()-2; i>=0; i--) {
        if (perm.get(i) < perm.get(i+1)) {
            for (int j=perm.size()-1; j>i; j--) {
                if (perm.get(j) > perm.get(i)) {
                    // Swap perm[i] and perm[j]
                    int temp = perm.get(i);
                    perm.set(i, perm.get(j));
                    perm.set(j, temp);

                    // Reverse the elements between perm[i+1] and perm[size-1]
                    int start = i + 1;
                    int end = perm.size() - 1;
                    while (start < end) {
                        temp = perm.get(start);
                        perm.set(start, perm.get(end));
                        perm.set(end, temp);
                        start++;
                        end--;
                    }

                    return perm;
                }
            }
        }
    }

    // If there is no next permutation, return an empty list
    return new ArrayList<Integer>();
}

