                public static List shunting_yard(ArrayList tokens) {
    // Creating hashmap for the precedence of the operators
    Map<String, Integer> precedence = new HashMap<String, Integer>();
    precedence.put("+",1);
    precedence.put("-",1);
    precedence.put("*",2);
    precedence.put("/",2);
    // Creating the empty array list and the array deque
    ArrayList rpntokens = new ArrayList(100);
    ArrayDeque opstack = new ArrayDeque();
    // Iterating over the list of tokens
    for (Object token: tokens) {
        // If the element is an integer, then we add it to the output list
        if (Integer.class.isInstance(token)) {
            rpntokens.add((Integer) token);
        // If the element is an operator, then we pop all operators from the stack with a lower or equal precedence
        // We then push the operator onto the stack
        } else {
            String operator = (String) token;
            while (!opstack.isEmpty() && precedence.get(operator) <= precedence.get(opstack.getLast())) {
                rpntokens.add(opstack.pop());
            }
            opstack.add(operator);
        }
    }
    // We now iterate through the stack and add all operators to the list in the order they are popped
    while (!opstack.isEmpty()) {
        rpntokens.add(opstack.pop());
    }
    return rpntokens;
}

