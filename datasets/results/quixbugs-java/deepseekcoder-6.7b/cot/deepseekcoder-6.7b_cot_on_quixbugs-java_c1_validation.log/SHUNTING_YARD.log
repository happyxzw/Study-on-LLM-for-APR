                PATCH:
                public static List shunting_yard(ArrayList tokens) {
    // create a Map that stores the precedence values of operators
    Map<String, Integer> precedence = new HashMap<String, Integer>();
    precedence.put("+",1);
    precedence.put("-",1);
    precedence.put("*",2);
    precedence.put("/",2);

    // create an ArrayList to store the output of the algorithm
    ArrayList rpntokens = new ArrayList(100);

    // create an ArrayDeque to store the operators
    ArrayDeque opstack = new ArrayDeque();

    for (Object token: tokens) {
        // if the token is an integer, add it to the output ArrayList
        if (Integer.class.isInstance(token)) {
            rpntokens.add((Integer) token);
        } else {
            // if the token is an operator
            String operator = (String) token;
            // while the operator stack is not empty and the precedence of the operator on top of the stack is greater than or equal to the precedence of the current operator
            while (!opstack.isEmpty() && precedence.get(operator) <= precedence.get(opstack.getLast())) {
                // pop the operator from the operator stack and add it to the output ArrayList
                rpntokens.add(opstack.pop());
            }
            // push the current operator to the operator stack
            opstack.push(operator);
        }
    }

    // while the operator stack is not empty
    while (!opstack.isEmpty()) {
        // pop the operator from the operator stack and add it to the output ArrayList
        rpntokens.add(opstack.pop());
    }

    // return the output ArrayList
    return rpntokens;
}

