                PATCH:
                public static int levenshtein(String source, String target) {
    // If source is empty, return the length of target
    if (source.isEmpty()) {
        return target.length();
    }
    // If target is empty, return the length of source
    else if (target.isEmpty()) {
        return source.length();
    }
    // If the first characters of source and target are the same,
    // recursively call the function with the rest of source and target
    else if (source.charAt(0) == target.charAt(0)) {
        return levenshtein(source.substring(1), target.substring(1));
    }
    // Otherwise, return 1 plus the minimum of the following options:
    // - Recursively call the function with the rest of source and the rest of target
    // - Recursively call the function with the rest of source and target
    // - Recursively call the function with the rest of target and source
    else {
        return 1 + Math.min(Math.min(
                levenshtein(source, target.substring(1)),
                levenshtein(source.substring(1), target.substring(1))),
                levenshtein(source.substring(1), target)
        );
    }
}

