                PATCH:
                public static int levenshtein(String source, String target) {
  // if source is empty, we have to add all the letters of the target to it.
  if (source.isEmpty() || target.isEmpty()) {
    return source.isEmpty() ? target.length() : source.length();
  }

  if (source.charAt(0) == target.charAt(0)) {
    // if the letters of the two strings match, we can call the function
    // on the substrings
    return 1 + levenshtein(source.substring(1), target.substring(1));
  }

  // if the letters don't match, we have three options:
  // 1. take the first letter of the source string and compare it with the entire
  // target string
  // 2. take the first letter of the target string and compare it with the entire
  // source string
  // 3. take the first letter of both strings and compare the substrings
  // of the two strings
  // then return the minimum edit distance of these three options
  return 1 + Math.min(Math.min(levenshtein(source, target.substring(1)),
                               levenshtein(source.substring(1), target)),
                      levenshtein(source.substring(1), target.substring(1)));
}

