                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    int n = perm.size();
    int i = n - 2;
    while (i >= 0 && perm.get(i) >= perm.get(i + 1)) {
        i--;
    }
    if (i < 0) {
        return new ArrayList<Integer>();
    }
    int j = n - 1;
    while (j >= 0 && perm.get(j) <= perm.get(i)) {
        j--;
    }
    int temp = perm.get(i);
    perm.set(i, perm.get(j));
    perm.set(j, temp);
    int left = i + 1, right = n - 1;
    while (left < right) {
        temp = perm.get(left);
        perm.set(left, perm.get(right));
        perm.set(right, temp);
        left++;
        right--;
    }
    return perm;
}

