                PATCH:
                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    // Find the index of the first digit from right to left that is smaller than the digit to its right
    int i = perm.size() - 2;
    while (i >= 0 && perm.get(i) >= perm.get(i + 1)) {
        i--;
    }
    if (i < 0) {
        return new ArrayList<Integer>(); // Return an empty list if the input is the last permutation
    }

    // Find the index of the first digit from right to left that is larger than the digit at index i
    int j = perm.size() - 1;
    while (j > i && perm.get(j) <= perm.get(i)) {
        j--;
    }

    // Swap the digits at indices i and j
    int temp = perm.get(i);
    perm.set(i, perm.get(j));
    perm.set(j, temp);

    // Reverse the digits to the right of index i
    j = perm.size() - 1;
    while (i < j) {
        temp = perm.get(i);
        perm.set(i, perm.get(j));
        perm.set(j, temp);
        i++;
        j--;
    }

    return perm;
}

