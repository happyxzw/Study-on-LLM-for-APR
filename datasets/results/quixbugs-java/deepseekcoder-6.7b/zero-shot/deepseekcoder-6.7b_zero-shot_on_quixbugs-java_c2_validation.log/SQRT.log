                PATCH:
                public static double sqrt(double x, double epsilon) {
    double approx = x / 2d;
    double prev;

    do {
        prev = approx;
        approx = (prev + x / prev) / 2d;
    } while (Math.abs(prev - approx) > epsilon);

    return approx;
}

