                public static ArrayList<Integer> kheapsort(ArrayList<Integer> arr, int k) {
    // Initialize the priority queue with the first k elements of the input array
    PriorityQueue<Integer> heap = new PriorityQueue<Integer>();
    for (Integer v : arr.subList(0,k)) {
        heap.add(v);
    }

    // Sort the remaining elements of the input array using the priority queue
    ArrayList<Integer> output = new ArrayList<Integer>();
    for (Integer x : arr) {
        heap.add(x);
        Integer popped = heap.poll();
        output.add(popped);
    }

    // Add the remaining elements of the priority queue to the output array
    while (!heap.isEmpty()) {
        output.add(heap.poll());
    }

    // Return the sorted array
    return output;
}

