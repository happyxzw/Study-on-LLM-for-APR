                PATCH:
                public static boolean detect_cycle(Node node) {
    Node hare = node;
    Node tortoise = node;
    while (hare != null && tortoise != null) {
        if (hare.getSuccessor() == null)
            return false;
        tortoise = tortoise.getSuccessor();
        hare = hare.getSuccessor().getSuccessor();
        if (hare == tortoise)
            return true;
    }
    return false;
}

