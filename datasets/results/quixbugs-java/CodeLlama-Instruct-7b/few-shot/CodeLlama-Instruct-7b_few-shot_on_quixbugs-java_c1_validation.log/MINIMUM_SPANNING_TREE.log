                PATCH:
                public static Set<WeightedEdge> minimum_spanning_tree(List<WeightedEdge> weightedEdges) {
    // Sort the edges by weight in ascending order
    Collections.sort(weightedEdges);

    // Create a map to store the connected components of the graph
    Map<Node, Set<Node>> groupByNode = new HashMap<>();

    // Create a set to store the minimum spanning tree
    Set<WeightedEdge> minSpanningTree = new HashSet<>();

    // Iterate over the edges
    for (WeightedEdge edge : weightedEdges) {
        Node vertex_u = edge.node1;
        Node vertex_v = edge.node2;

        // If the vertices are not connected, add the edge to the minimum spanning tree and update the connected components map
        if (!groupByNode.containsKey(vertex_u)) {
            groupByNode.put(vertex_u, new HashSet<>(Arrays.asList(vertex_u)));
        }
        if (!groupByNode.containsKey(vertex_v)) {
            groupByNode.put(vertex_v, new HashSet<>(Arrays.asList(vertex_v)));
        }
        if (!groupByNode.get(vertex_u).contains(vertex_v)) {
            minSpanningTree.add(edge);
            groupByNode = update(groupByNode, vertex_u, vertex_v);
        }
    }
    return minSpanningTree;
}

