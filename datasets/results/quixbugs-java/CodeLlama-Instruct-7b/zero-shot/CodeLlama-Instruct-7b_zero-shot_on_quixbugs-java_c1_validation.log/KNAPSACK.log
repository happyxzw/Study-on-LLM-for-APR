    int n = items.length;
    int memo[][] = new int[n + 1][capacity + 1];
    for (int i = 0; i <= n; i++) {
        for (int j = 0; j <= capacity; j++) {
            if (i == 0 || j == 0) {
                memo[i][j] = 0;
            } else if (items[i - 1][0] < j) {
                memo[i][j] = Math.max(memo[i - 1][j], items[i - 1][1] + memo[i - 1][j - items[i - 1][0]]);
            } else {
                memo[i][j] = memo[i - 1][j];
            }
        }
    }
    return memo[n][capacity];
}

