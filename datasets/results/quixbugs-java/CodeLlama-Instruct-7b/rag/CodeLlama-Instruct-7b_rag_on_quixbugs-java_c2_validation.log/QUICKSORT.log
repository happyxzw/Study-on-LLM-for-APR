    }
    Integer pivot = arr.get(0);
    ArrayList<Integer> lesser = new ArrayList<Integer>();
    ArrayList<Integer> greater = new ArrayList<Integer>();
    for (Integer x : arr.subList(1, arr.size())) {
        if (x < pivot) {
