                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    int i = perm.size() - 1;
    while (perm.get(i) <= perm.get(i - 1)) {
        i -= 1;
    }
    if (i == 0)
        return new ArrayList<Integer>();
    else {
        int j = perm.size() - 1;
        while (perm.get(j) <= perm.get(i - 1)) {
            j -= 1;
        }
        int temp = perm.get(i - 1);
        perm.set(i - 1, perm.get(j));
        perm.set(j, temp);
        int q = perm.size() - 1;
        while (i < q) {
            int temp2 = perm.get(i);
            perm.set(i, perm.get(q));
            perm.set(q, temp2);
            i += 1;
            q -= 1;
        }
        return perm;
    }
}

