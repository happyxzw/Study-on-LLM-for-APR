                PATCH:
                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
        ArrayList<Integer> next_perm = perm;
        int i = next_perm.size() - 2;
        while (i != -1 && next_perm.get(i) >= next_perm.get(i + 1))
            i -= 1;

        if (i == -1) {
            Collections.reverse(next_perm);
            return next_perm;
        }

        int j = next_perm.size() - 1;
        while (next_perm.get(j) <= next_perm.get(i))
            j -= 1;

        Collections.swap(next_perm, i, j);

        Collections.reverse(next_perm.subList(i + 1, next_perm.size()));
        return next_perm;
    }

