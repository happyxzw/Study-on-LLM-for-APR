                PATCH:
                public static ArrayList<Integer> sieve(Integer max) {
	ArrayList<Integer> primes = new ArrayList<Integer>();
    for (int n=2; n<max+1; n++) {
        boolean is_prime = true;
        for (int i=0; i<primes.size(); i++) {
            if (n % primes.get(i) == 0) {
                is_prime = false;
            }
        }
        if (is_prime) {
            primes.add(n);
        }
    }
    return primes;
}

