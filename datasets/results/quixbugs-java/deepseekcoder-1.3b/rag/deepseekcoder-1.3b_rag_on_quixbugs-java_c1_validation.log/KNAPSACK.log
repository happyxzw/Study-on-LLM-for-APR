                PATCH:
                public static int knapsack(int capacity, int [][] items) {
    int n = items.length;
    int[][] memo = new int[n + 1][capacity + 1];
    int weight, value;
    for (int i = 0; i <= n; i++)
    {
        for (int j = 0; j <= capacity; j++)
        {
            if (i == 0 || j == 0) {
                memo[i][j] = 0;
            }
            else {
                weight = items[i - 1][0];
                value = items[i - 1][1];
                if (weight > j) {
                    memo[i][j] = memo[i - 1][j];
                } else {
                    memo[i][j] = Math.max(value + memo[i - 1][j - weight], memo[i - 1][j]);
                }
            }
        }
    }
    return memo[n][capacity];
}

