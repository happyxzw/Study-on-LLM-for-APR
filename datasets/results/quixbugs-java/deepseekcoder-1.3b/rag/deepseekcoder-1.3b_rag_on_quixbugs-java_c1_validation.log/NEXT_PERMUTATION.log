                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    if (perm.size() <= 1) {
        return new ArrayList<Integer>();
    }

    int index = perm.size() - 2;
    while (index >= 0 && perm.get(index) >= perm.get(index + 1)) {
        index--;
    }

    if (index < 0) {
        return new ArrayList<Integer>();
    }

    int swap_index = perm.size() - 1;
    while (perm.get(swap_index) <= perm.get(index)) {
        swap_index--;
    }

    int temp = perm.get(index);
    perm.set(index, perm.get(swap_index));
    perm.set(swap_index, temp);

    int begin = index + 1;
    int end = perm.size() - 1;
    while (begin < end) {
        temp = perm.get(begin);
        perm.set(begin, perm.get(end));
        perm.set(end, temp);
        begin++;
        end--;
    }

    return perm;
}

