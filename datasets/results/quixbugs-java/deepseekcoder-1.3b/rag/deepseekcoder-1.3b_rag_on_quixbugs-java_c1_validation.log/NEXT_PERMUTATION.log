        int temp = perm.get(j);
        perm.set(j, perm.get(i));
        perm.set(i, temp);

        ArrayList<Integer> reversed = new ArrayList<Integer>(100);
        for (int k=i+1; k<perm.size(); k++) {
            reversed.add(perm.get(k));
        }
        int q = perm.size()-1;
        for (Integer replace : reversed) {
            perm.set(q, replace);
            q--;
        }
        return perm;
    }

