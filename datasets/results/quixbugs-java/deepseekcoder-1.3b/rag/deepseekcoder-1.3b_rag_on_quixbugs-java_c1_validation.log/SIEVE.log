                PATCH:
                public static ArrayList<Integer> sieve(Integer max) {
    ArrayList<Integer> primes = new ArrayList<Integer>();
    for(int n = 2; n <= max; n++) {
        boolean is_prime = true;
        for(Integer p : primes) {
            if(n % p == 0) {
                is_prime = false;
                break;
            }
        }
        if(is_prime) primes.add(n);
    }
    return primes;
}

