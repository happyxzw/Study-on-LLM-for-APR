                public static Integer kth(ArrayList<Integer> arr, int k) {
    int pivot = arr.get(0);
    ArrayList<Integer> less = new ArrayList<Integer>(arr.size());
    ArrayList<Integer> greater = new ArrayList<Integer>(arr.size());
    for (Integer x : arr) {
        if (x < pivot) {
            less.add(x);
        } else if (x > pivot) {
            greater.add(x);
        }
    }
    int num_less = less.size();
    int num_lessoreq = arr.size() - greater.size();
    if (k < num_less) {
        return kth(less, k);
    } else if (k >= num_lessoreq) {
        return kth(greater, k - num_lessoreq);
    } else {
            return pivot;
    }
}

