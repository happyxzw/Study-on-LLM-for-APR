    op.put("-", (a, b) -> a - b);
    op.put("*", (a, b) -> a * b);
    op.put("/", (a, b) -> a / b);
    Stack stack = new Stack();
    for (Object token : tokens) {
        if (Double.class.isInstance(token)) {
            stack.push((Double) token);
        } else {
            token = (String) token;
            Double a = (Double) stack.pop();
