        Node node = toProcess.get(0);
        toProcess.remove(0);
        if (node.getPredecessors().isEmpty()) {
            orderedNodes.add(node);
        }
        for (Node nextNode : node.getSuccessors()) {
            toProcess.removeAll(nextNode.getSuccessors());
            if (toProcess.contains(nextNode)) {
                orderedNodes.add(nextNode);
            }
        }
    }
    return orderedNodes;
}

