                PATCH:
                public static int lis(int[] arr) {
    int n = arr.length;
    int[] lis = new int[n];
    int[] next_to_last = new int[n];
    lis[0] = 1;
    next_to_last[n - 1] = -1;
    for (int i = 0; i < n; i++) {
        lis[i] = 1;
        next_to_last[i] = -1;
        for (int j = i - 1; j >= 0; j--) {
            if (arr[j] < arr[i]) {
                if (lis[j] + 1 > lis[i]) {
                    lis[i] = lis[j] + 1;
                    next_to_last[i] = j;
                }
            }
        }
    }
    int max = 1;
    int maxIndex = 0;
    for (int i = 0; i < n; i++) {
        if (lis[i] > max) {
            max = lis[i];
            maxIndex = i;
        }
    }
    int[] longest = new int[max];
    int length = 0;
    while (maxIndex != -1) {
        longest[length] = arr[maxIndex];
        maxIndex = next_to_last[maxIndex];
        length++;
    }
    return length;
}

