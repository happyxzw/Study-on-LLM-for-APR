                PATCH:
                public static String longest_common_subsequence(String a, String b) {
    // if the two strings are empty, return an empty string
    if (a.isEmpty() || b.isEmpty()) {
        return "";
    }
    // if the first characters of the two strings are the same, return the first character
    // plus the longest common subsequence of the remaining characters
    if (a.charAt(0) == b.charAt(0)) {
        return a.charAt(0) + longest_common_subsequence(a.substring(1), b);
    }
    // otherwise, recursively call the function with the first character of each string removed
    else {
        String fst = longest_common_subsequence(a, b.substring(1));
        String snd = longest_common_subsequence(a.substring(1), b);
        // return the longest common subsequence of the two strings
        return fst.length() >= snd.length() ? fst : snd;
    }
}

