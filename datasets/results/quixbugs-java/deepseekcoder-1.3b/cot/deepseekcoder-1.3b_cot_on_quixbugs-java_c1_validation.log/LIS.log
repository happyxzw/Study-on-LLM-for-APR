                PATCH:
                public static int lis(int[] arr) {
    // Create the list of length 100
    List<Integer> list = new ArrayList<>(100);
    for (int i = 0; i < 100; i++) {
        list.add(0);
    }

    int longest = 0;
    for (int val : arr) {
        // Find the longest prefix of val that has a smaller last value
        int index = 0;
        for (int i = 0; i < longest; i++) {
            if (list.get(i) < val) {
                index = i;
            }
        }

        // Update the list to have a new entry
        list.set(index, val);

        // Update longest
        if (index == longest) {
            longest++;
        }
    }

    // Return the longest list
    return longest;
}

