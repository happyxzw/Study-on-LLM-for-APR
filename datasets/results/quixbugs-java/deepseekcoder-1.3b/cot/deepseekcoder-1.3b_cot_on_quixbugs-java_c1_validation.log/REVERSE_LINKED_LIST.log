                PATCH:
                public static Node reverse_linked_list(Node node) {
    if (node == null) {
        return null;
    }
    Node prevnode = node;
    Node nextnode = prevnode.getSuccessor();
    prevnode.setSuccessor(null);
    while (nextnode != null) {
        Node temp = nextnode.getSuccessor();
        nextnode.setSuccessor(prevnode);
        prevnode = nextnode;
        nextnode = temp;
        }
    return prevnode;
}

