                PATCH:
                public static Node reverse_linked_list(Node node) {
    if (node == null || node.getSuccessor() == null) {
        return node;
    }
    Node newHead = reverse_linked_list(node.getSuccessor());
    node.getSuccessor().setSuccessor(node);
    node.setSuccessor(null);
    return newHead;
}

