                PATCH:
                public static Integer kth(ArrayList<Integer> arr, int k) {
    int pivot = arr.get(0);
    ArrayList<Integer> less, more;
    less = new ArrayList<Integer>(arr.size());
    more = new ArrayList<Integer>(arr.size());
    for (Integer x : arr) {
        if (x < pivot) {
            less.add(x);
        } else {
            more.add(x);
        }
    }
    int num_less = less.size();
    int num_lessoreq = arr.size() - more.size();
    if (k < num_less) {
        return kth(less, k);
    } else if (k >= num_lessoreq) {
        return kth(more, k - num_lessoreq);
    } else {
            return pivot;
    }
}

