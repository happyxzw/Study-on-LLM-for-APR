    if (total == 0) {
        return 1;
    }
    if (total < 0) {
            return 0;
    }
    int first = coins[0];
    if (first > total) {
        return possible_change(Arrays.copyOfRange(coins, 1, coins.length), total);
    }
    int[] rest = Arrays.copyOfRange(coins, 1, coins.length);
    return possible_change(coins, total-first) + possible_change(rest, total);
}

