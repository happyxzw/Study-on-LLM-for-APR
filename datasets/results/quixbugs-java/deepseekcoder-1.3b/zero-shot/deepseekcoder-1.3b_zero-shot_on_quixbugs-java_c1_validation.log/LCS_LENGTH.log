                public static Integer lcs_length(String s, String t) {
    int[][] dp = new int[s.length()][t.length()];
    for (int i=0; i<s.length(); i++) {
        dp[i][0] = 0;
    }
    for (int j=0; j<t.length(); j++) {
        dp[0][j] = 0;
    }
    for (int i=0; i<s.length(); i++) {
        for (int j=0; j<t.length(); j++) {
            if (s.charAt(i) == t.charAt(j)) {
                if (i>0 && j>0) {
                    dp[i][j] = dp[i-1][j-1] + 1;
                } else {
