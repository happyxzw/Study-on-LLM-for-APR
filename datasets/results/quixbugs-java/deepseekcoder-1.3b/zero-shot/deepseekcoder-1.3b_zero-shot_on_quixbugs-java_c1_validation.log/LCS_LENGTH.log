                PATCH:
                public static Integer lcs_length(String s, String t) {
    if (s.length() == 0 || t.length() == 0) {
        return 0;
    }
    if (s.charAt(s.length() - 1) == t.charAt(t.length() - 1)) {
        return lcs_length(s.substring(0,s.length()-1),t.substring(0,t.length()-1)) + 1;
    } else {
        return Math.max(lcs_length(s.substring(0,s.length()-1),t),lcs_length(s,t.substring(0,t.length()-1)));
    }
}

