                public static int possible_change(int[] coins, int total) {
    int[] results = new int[total+1];
    results[0] = 1;
    for (int j = 0; j < coins.length; j++) {
        for (int i = coins[j]; i <= total; i++) {
            results[i] += results[i-coins[j]];
        }
    }
    return results[total];
}

