                public static String next_palindrome(int[] digit_list) {
    int n = digit_list.length;
    int high_mid = Math.floorDiv(n, 2);
    int low_mid = Math.floorDiv(n - 1, 2);

    while (high_mid < n && low_mid >= 0) {
        if (digit_list[high_mid] == 9) {
            digit_list[high_mid] = 0;
            digit_list[low_mid] = 0;
            high_mid += 1;
            low_mid -= 1;
        } else {
            digit_list[high_mid] += 1;
            if (low_mid != high_mid) {
                digit_list[low_mid] += 1;
            }
            break;
        }
    }

    // If we exit the loop without breaking, it means all digits were 9
    if (high_mid == n || low_mid == -1) {
        ArrayList<Integer> otherwise = new ArrayList<>();
        otherwise.add(1);
        otherwise.addAll(Collections.nCopies(n, 0));
        otherwise.add(1);
        return otherwise.toString();
    }

    // Reflect the left half to the right half to create the palindrome
    for (int i = 0; i <= low_mid; i++) {
        digit_list[n - 1 - i] = digit_list[i];
    }

    return Arrays.toString(digit_list);
}

