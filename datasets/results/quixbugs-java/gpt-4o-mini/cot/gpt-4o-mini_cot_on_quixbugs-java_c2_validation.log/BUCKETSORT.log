                PATCH:
                public static ArrayList<Integer> bucketsort(ArrayList<Integer> arr, int k) {
    ArrayList<Integer> counts = new ArrayList<Integer>(Collections.nCopies(k, 0));
    for (Integer x : arr) {
        if (x < k) { // Ensure x is within the range [0, k-1]
            counts.set(x, counts.get(x) + 1);
        }
    }
    ArrayList<Integer> sorted_arr = new ArrayList<Integer>();
    for (int i = 0; i < counts.size(); i++) { // Iterate over counts
        sorted_arr.addAll(Collections.nCopies(counts.get(i), i)); // Use counts to build sorted_arr
    }
    return sorted_arr;
}

