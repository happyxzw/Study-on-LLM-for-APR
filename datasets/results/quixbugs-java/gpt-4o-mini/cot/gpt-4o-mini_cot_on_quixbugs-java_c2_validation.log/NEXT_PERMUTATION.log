                    int temp_i = next_perm.get(i);
                    next_perm.set(i, temp_j);
                    next_perm.set(j, temp_i);

                    // Reverse the sublist after the index i
                    Collections.reverse(next_perm.subList(i + 1, next_perm.size()));

                    return next_perm;
                }
