                public static ArrayList<Integer> sieve(Integer max) {
    ArrayList<Integer> primes = new ArrayList<Integer>();
    for (int n=2; n<max+1; n++) {
        boolean isPrime = true; // Assume n is prime until proven otherwise
        for (Integer prime : primes) {
            if (prime * prime > n) break; // No need to check beyond sqrt(n)
            if (n % prime == 0) { // Check divisibility
                isPrime = false; // n is not prime
                break;
            }
        }
        if (isPrime) {
            primes.add(n); // Add n to primes if it is prime
        }
    }
    return primes;
}

