                PATCH:
                public static ArrayList<Integer> get_factors(int n) {
    ArrayList<Integer> factors = new ArrayList<Integer>();
    if (n == 1) {
        return factors;
    }
    int max = (int)(Math.sqrt(n) + 1.0);
    for (int i = 2; i < max; i++) {
        while (n % i == 0) {
            factors.add(i);
            n /= i;
        }
    }
    if (n > 1) { // If n is still greater than 1, it means n is prime
        factors.add(n);
    }
    return factors;
}

