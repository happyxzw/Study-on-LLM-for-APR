                PATCH:
                public static Double rpn_eval(ArrayList<Object> tokens) {
    Map<String, BinaryOperator<Double>> op = new HashMap<String, BinaryOperator<Double>>();
    op.put("+", (a, b) -> a + b);
    op.put("-", (a, b) -> a - b);
    op.put("*", (a, b) -> a * b);
    op.put("/", (a, b) -> a / b);
    Stack<Double> stack = new Stack<>(); // Specify type for stack
    for (Object token : tokens) {
        if (token instanceof Double) { // Use instanceof for type checking
            stack.push((Double) token);
        } else {
            String operator = (String) token; // Rename variable for clarity
            Double b = stack.pop(); // Correct order for RPN
            Double a = stack.pop();
            BinaryOperator<Double> bin_op = op.get(operator);
            Double result = bin_op.apply(a, b); // Rename variable for clarity
            stack.push(result);
        }
    }
    return stack.pop(); // No need to cast, stack is typed
}

