                public static Integer kth(ArrayList<Integer> arr, int k) {
    if (arr.isEmpty()) {
        return null; // Added check for empty array to prevent IndexOutOfBoundsException
    }

    int pivot = arr.get(0);
    ArrayList<Integer> below = new ArrayList<Integer>(arr.size());
    ArrayList<Integer> above = new ArrayList<Integer>(arr.size());

    for (Integer x : arr) {
        if (x < pivot) {
            below.add(x);
        } else if (x > pivot) {
            above.add(x);
        }
    }

    int num_less = below.size();
    // Changed num_lessoreq calculation to account for duplicates of pivot
    int num_lessoreq = num_less + Collections.frequency(arr, pivot); 

    if (k < num_less) {
        return kth(below, k);
    } else if (k >= num_lessoreq) {
        return kth(above, k - num_less - Collections.frequency(arr, pivot)); // Adjusted index for above
    } else {
        return pivot;
    }
}

