                public static Integer kth(ArrayList<Integer> arr, int k) {
    if (arr.isEmpty()) {
        return null; // Handle the case where the input array is empty
    }

    int pivot = arr.get(0);
    ArrayList<Integer> below = new ArrayList<Integer>();
    ArrayList<Integer> above = new ArrayList<Integer>();

    for (Integer x : arr) {
        if (x < pivot) {
            below.add(x);
        } else if (x > pivot) {
            above.add(x);
        }
    }

    int num_less = below.size();
    int num_equal = arr.size() - below.size() - above.size(); // Count the number of elements equal to pivot
    int num_lessoreq = num_less + num_equal; // Update num_lessoreq to include equal elements

    if (k < num_less) {
        return kth(below, k);
    } else if (k >= num_less + num_equal) {
        return kth(above, k - num_less - num_equal); // Adjust k for the recursive call
    } else {
        return pivot; // The pivot is the k-th element when k is within the equal range
    }
}

