                PATCH:
                public static Integer lcs_length(String s, String t) {
    Map<Integer, Map<Integer,Integer>> dp = new HashMap<Integer,Map<Integer,Integer>>();
    for (int i=0; i <= s.length(); i++) { // Changed '<' to '<=' to accommodate the base case
        Map<Integer,Integer> initialize = new HashMap<Integer,Integer>();
        dp.put(i, initialize);
        for (int j=0; j <= t.length(); j++) { // Changed '<' to '<=' to accommodate the base case
            Map<Integer,Integer> internal_map = dp.get(i);
            internal_map.put(j,0); // This initializes the base case for both strings
            dp.put(i, internal_map);
        }
    }
    for (int i=1; i <= s.length(); i++) { // Changed to start from 1 to use the initialized base case
        for (int j=1; j <= t.length(); j++) { // Changed to start from 1 to use the initialized base case
            if (s.charAt(i-1) == t.charAt(j-1)) { // Changed index to i-1 and j-1 since i and j start from 1
                int insert_value = dp.get(i-1).get(j-1) + 1; // Changed to get(j-1) to access previous value correctly
                dp.get(i).put(j, insert_value); // Directly put value without re-fetching internal_map
            } else {
                dp.get(i).put(j, Math.max(dp.get(i-1).get(j), dp.get(i).get(j-1))); // Added case for non-matching characters
            }
        }
    }
    return dp.get(s.length()).get(t.length()); // Return the result from the last cell
}

