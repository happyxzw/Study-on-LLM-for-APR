                public static Integer lcs_length(String s, String t) {
    Map<Integer, Map<Integer,Integer>> dp = new HashMap<>();
    for (int i = 0; i <= s.length(); i++) { // Change the loop to go until s.length()
        Map<Integer, Integer> initialize = new HashMap<>();
        dp.put(i, initialize);
        for (int j = 0; j <= t.length(); j++) { // Change the loop to go until t.length()
            dp.get(i).put(j, 0); // Directly put the value without needing to get internal_map
        }
    }
    for (int i = 1; i <= s.length(); i++) { // Start from 1 to avoid index -1
        for (int j = 1; j <= t.length(); j++) { // Start from 1 to avoid index -1
            if (s.charAt(i - 1) == t.charAt(j - 1)) { // Use i-1 and j-1 for correct indexing
                dp.get(i).put(j, dp.get(i - 1).get(j - 1) + 1); // Use the previous values correctly
            } else {
                dp.get(i).put(j, Math.max(dp.get(i - 1).get(j), dp.get(i).get(j - 1))); // Correctly update based on max
            }
        }
    }
    return dp.get(s.length()).get(t.length()); // Return the LCS length directly
}

