    for (int i = 0; i <= s.length(); i++) { // Use <= to include the base case for empty string
        Map<Integer, Integer> initialize = new HashMap<Integer, Integer>();
        dp.put(i, initialize);
        for (int j = 0; j <= t.length(); j++) { // Use <= to include the base case for empty string
            initialize.put(j, 0); // Initialize all values to 0
        }
    }

    for (int i = 1; i <= s.length(); i++) { // Start from 1 to handle base case
        for (int j = 1; j <= t.length(); j++) { // Start from 1 to handle base case
            if (s.charAt(i - 1) == t.charAt(j - 1)) { // Use i-1 and j-1 to access characters
                dp.get(i).put(j, dp.get(i - 1).get(j - 1) + 1); // Correctly access the previous character's count
            } else {
                dp.get(i).put(j, Math.max(dp.get(i - 1).get(j), dp.get(i).get(j - 1))); // Take max of left and top
            }
        }
    }

    return dp.get(s.length()).get(t.length()); // Return the last cell which contains the length of LCS
}

