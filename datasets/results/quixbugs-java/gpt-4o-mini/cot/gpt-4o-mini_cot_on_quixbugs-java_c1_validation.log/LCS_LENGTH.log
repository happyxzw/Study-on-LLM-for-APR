                PATCH:
                public static Integer lcs_length(String s, String t) {
    int m = s.length();
    int n = t.length();
    int[][] dp = new int[m + 1][n + 1]; // Use a 2D array instead of a map

    // Fill the dp array
    for (int i = 1; i <= m; i++) {
        for (int j = 1; j <= n; j++) {
            if (s.charAt(i - 1) == t.charAt(j - 1)) {
                dp[i][j] = dp[i - 1][j - 1] + 1; // If characters match, increment the count
            } else {
                dp[i][j] = Math.max(dp[i - 1][j], dp[i][j - 1]); // Take the maximum from left or top
            }
        }
    }

    return dp[m][n]; // The length of LCS is found at dp[m][n]
}

