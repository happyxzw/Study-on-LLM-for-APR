                    int temp_j = perm.get(j);
                    int temp_i = perm.get(i);
                    next_perm.set(i, temp_j);
                    next_perm.set(j, temp_i);
                    Collections.reverse(next_perm.subList(i + 1, next_perm.size())); // Simplified reversal using Collections
                    return next_perm;
                }
            }
        }
    }
    Collections.sort(perm); // Return the smallest permutation if no next permutation is found
    return perm;
}

