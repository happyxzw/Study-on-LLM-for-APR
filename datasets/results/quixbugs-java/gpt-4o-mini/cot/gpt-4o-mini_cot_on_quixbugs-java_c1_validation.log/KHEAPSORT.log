                public static ArrayList<Integer> kheapsort(ArrayList<Integer> arr, int k) {
    PriorityQueue<Integer> heap = new PriorityQueue<Integer>();
    for (Integer v : arr.subList(0, Math.min(k, arr.size()))) { // Fix: Ensure k is not greater than arr size
        heap.add(v);
    }
    ArrayList<Integer> output = new ArrayList<Integer>();
    for (Integer x : arr) {
        heap.add(x);
        if (heap.size() > k) { // Fix: Maintain heap size to k
            heap.poll(); // Remove the smallest element if size exceeds k
        }
        Integer popped = heap.peek(); // Fix: Use peek to get the smallest element without removing it
        output.add(popped);
    }
    while (!heap.isEmpty()) {
        output.add(heap.poll());
    }
    return output;
}

