                PATCH:
                public static ArrayList<Integer> get_factors(int n) {
    ArrayList<Integer> factors = new ArrayList<Integer>();
    if (n == 1) {
        return factors; // Return an empty list for the input 1
    }
    int max = (int)(Math.sqrt(n) + 1.0);
    for (int i = 2; i < max; i++) {
        while (n % i == 0) { // Use a while loop to account for multiple factors
            factors.add(i); // Add the factor to the list
            n /= i; // Reduce n by dividing it by the factor
        }
    }
    if (n > 1) { // If n is still greater than 1, it must be prime
        factors.add(n); // Add the remaining prime factor
    }
    return factors; // Return the list of factors
}

