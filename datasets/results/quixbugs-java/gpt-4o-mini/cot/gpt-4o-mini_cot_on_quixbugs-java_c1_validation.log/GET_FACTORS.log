                PATCH:
                public static ArrayList<Integer> get_factors(int n) {
    if (n == 1) {
        return new ArrayList<Integer>();
    }
    ArrayList<Integer> factors = new ArrayList<Integer>(); // Initialize a list to hold all factors
    int max = (int)(Math.sqrt(n) + 1.0);
    for (int i = 2; i < max; i++) {
        while (n % i == 0) { // Use a while loop to handle multiple factors of the same number
            factors.add(i); // Add the factor to the list
            n /= i; // Divide n by the factor
        }
    }
    if (n > 1) { // If there is any prime factor left
        factors.add(n); // Add the remaining prime factor
    }
    return factors; // Return the complete list of factors
}

