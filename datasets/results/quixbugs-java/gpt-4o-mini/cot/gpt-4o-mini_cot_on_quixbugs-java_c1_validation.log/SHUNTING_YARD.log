                PATCH:
                public static List shunting_yard(ArrayList tokens) {
    Map<String, Integer> precedence = new HashMap<String, Integer>();
    precedence.put("+", 1);
    precedence.put("-", 1);
    precedence.put("*", 2);
    precedence.put("/", 2);
    ArrayList<Object> rpntokens = new ArrayList<>(100); // Specify type for rpntokens
    ArrayDeque<String> opstack = new ArrayDeque<>(); // Specify type for opstack
    for (Object token : tokens) {
        if (token instanceof Integer) { // Use instanceof for type checking
            rpntokens.add(token); // No need to cast as Integer
        } else {
            String operator = (String) token;
            while (!opstack.isEmpty() && precedence.get(operator) <= precedence.get(opstack.getLast())) {
                rpntokens.add(opstack.pop());
            }
            opstack.push(operator); // Add the operator to the stack
        }
    }
    while (!opstack.isEmpty()) {
        rpntokens.add(opstack.pop());
    }
    return rpntokens;
}

