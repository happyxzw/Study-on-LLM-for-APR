                public static ArrayList<Node> topological_ordering (List<Node> directedGraph) {
    ArrayList<Node> orderedNodes = new ArrayList<Node>();
    // Use a queue to process nodes with no predecessors
    Queue<Node> queue = new LinkedList<>();

    for (Node node : directedGraph) {
        if (node.getPredecessors().isEmpty()) {
            queue.add(node);
        }
    }

    while (!queue.isEmpty()) {
        Node node = queue.poll();
        orderedNodes.add(node);

        for (Node nextNode : node.getSuccessors()) {
            // Remove the current node from the next node's predecessors
            nextNode.removePredecessor(node);
            // If nextNode has no more predecessors, add it to the queue
            if (nextNode.getPredecessors().isEmpty() && !orderedNodes.contains(nextNode)) {
                queue.add(nextNode);
            }
        }
    }
    return orderedNodes;
}

