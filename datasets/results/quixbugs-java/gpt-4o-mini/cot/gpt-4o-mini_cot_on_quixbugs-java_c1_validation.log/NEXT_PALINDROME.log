                PATCH:
                public static String next_palindrome(int[] digit_list) {
    int high_mid = Math.floorDiv(digit_list.length, 2);
    int low_mid = Math.floorDiv(digit_list.length - 1, 2);
    boolean incremented = false; // Flag to track if we have incremented the middle digits

    while (high_mid < digit_list.length && low_mid >= 0) {
        if (digit_list[high_mid] == 9) {
            digit_list[high_mid] = 0;
            digit_list[low_mid] = 0;
            high_mid += 1;
            low_mid -= 1;
        } else {
            digit_list[high_mid] += 1; // Increment the middle digit
            if (low_mid != high_mid) {
                digit_list[low_mid] += 1; // Increment the mirrored digit
            }
            incremented = true; // Set flag to true
            break; // Exit the loop after incrementing
        }
    }

    if (!incremented) { // Check if we never incremented
        ArrayList<Integer> otherwise = new ArrayList<Integer>();
        otherwise.add(1);
        otherwise.addAll(Collections.nCopies(digit_list.length, 0));
        otherwise.add(1);
        return String.valueOf(otherwise);
    }

    // Create the palindrome from the modified digits
    for (int i = 0; i < low_mid + 1; i++) {
        digit_list[digit_list.length - 1 - i] = digit_list[i]; // Mirror the first half to the second half
    }

    return Arrays.toString(digit_list);
}

