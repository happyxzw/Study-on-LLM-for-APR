                PATCH:
                public static List<Pair<Integer,Integer>> hanoi(int height, int start, int end) {
    ArrayList<Pair<Integer,Integer>> steps = new ArrayList<Pair<Integer,Integer>>();
    if (height > 0) {
        // Create a set of possible pegs to use for the helper
        PriorityQueue<Integer> peg_set = new PriorityQueue<Integer>();
        peg_set.add(1);
        peg_set.add(2);
        peg_set.add(3);
        peg_set.remove(start); // Remove the start peg
        peg_set.remove(end);   // Remove the end peg
        int helper = peg_set.poll(); // Get the remaining peg as helper
        steps.addAll(hanoi(height-1, start, helper)); // Move discs from start to helper
        steps.add(new Pair<Integer,Integer>(start, end)); // Move disc from start to end
        steps.addAll(hanoi(height-1, helper, end)); // Move discs from helper to end
    }
    return steps;
}

