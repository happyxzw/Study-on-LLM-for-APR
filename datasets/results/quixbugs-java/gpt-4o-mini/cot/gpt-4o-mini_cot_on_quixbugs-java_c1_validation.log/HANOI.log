                PATCH:
                public static List<Pair<Integer,Integer>> hanoi(int height, int start, int end) {
    ArrayList<Pair<Integer,Integer>> steps = new ArrayList<Pair<Integer,Integer>>();
    if (height > 0) {
        // Use a fixed array for the helper rod since there are only three rods
        int[] rods = {1, 2, 3};
        // Remove the start and end rods from the array to find the helper rod
        int helper = 0;
        for (int rod : rods) {
            if (rod != start && rod != end) {
                helper = rod; // Assign the helper rod
                break; // No need to continue once the helper is found
            }
        }
        steps.addAll(hanoi(height-1, start, helper));
        steps.add(new Pair<Integer,Integer>(start, end)); // Move directly from start to end
        steps.addAll(hanoi(height-1, helper, end));
    }
    return steps;
}

