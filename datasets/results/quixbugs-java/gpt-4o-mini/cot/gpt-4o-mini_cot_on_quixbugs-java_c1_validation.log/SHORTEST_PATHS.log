                public static Map<String, Integer> shortest_paths(String source, Map<List<String>, Integer> weight_by_edge) {
    Map<String, Integer> weight_by_node = new HashMap<String, Integer>();
    for (List<String> edge : weight_by_edge.keySet()) {
        weight_by_node.put(edge.get(0), INF); // Initialize both nodes in the edge with INF
        weight_by_node.put(edge.get(1), INF);
    }
    weight_by_node.put(source, 0); // Set the source node weight to 0

    for (int i = 0; i < weight_by_node.size() - 1; i++) { // Iterate |V| - 1 times
        for (List<String> edge : weight_by_edge.keySet()) {
            // Only update if the current node's weight is not INF
            if (weight_by_node.get(edge.get(0)) != INF) {
                int update_weight = weight_by_node.get(edge.get(0)) + weight_by_edge.get(edge);
                if (update_weight < weight_by_node.get(edge.get(1))) { // Check if update is needed
                    weight_by_node.put(edge.get(1), update_weight); // Update the weight of the destination node
                }
            }
        }
    }
    return weight_by_node; // Return the final weights
}

