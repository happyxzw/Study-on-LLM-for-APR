                public static ArrayList<Integer> sieve(Integer max) {
    ArrayList<Integer> primes = new ArrayList<Integer>();
    for (int n = 2; n <= max; n++) { // Changed the loop condition to n <= max
        boolean isPrime = true; // Initialize isPrime as true for each n
        for (int prime : primes) { // Check against existing primes
            if (prime * prime > n) break; // No need to check beyond sqrt(n)
            if (n % prime == 0) { // If n is divisible by a prime, it's not prime
                isPrime = false;
                break; // Exit loop early if n is found to be not prime
            }
        }
        if (isPrime) {
            primes.add(n); // Only add n to primes if it's prime
        }
    }
    return primes;
}

