        } else {
            end = end == 0 ? cols : end; // Prevents empty lines when no space found
        }
        line = text.substring(0,end).trim(); // Trim to avoid leading spaces
        text = text.substring(end).trim(); // Trim to avoid leading spaces in next iteration
        lines.add(line);
    }
    if (!text.isEmpty()) { // Add any remaining text
        lines.add(text.trim());
    }
    return lines;
}

