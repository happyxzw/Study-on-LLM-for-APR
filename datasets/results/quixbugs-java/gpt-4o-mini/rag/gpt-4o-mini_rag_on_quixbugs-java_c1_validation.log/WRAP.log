                PATCH:
                public static ArrayList<String> wrap(String text, int cols) {
    ArrayList<String> lines = new ArrayList<String>();
    String line;
    while (text.length() > cols) {
        int end = text.lastIndexOf(" ", cols); 
        if (end == -1) {
            end = cols;
        } else if (end == 0) {
            end = Math.min(cols, text.length()); // Prevents empty line
        }
        line = text.substring(0,end).trim(); // Trims any leading whitespace
        text = text.substring(end).trim(); // Trims leading whitespace from the remaining text
        lines.add(line);
    }
    if (!text.isEmpty()) {
        lines.add(text.trim()); // Adds the remaining text if it's not empty
    }
    return lines;
}

