                public static ArrayList<String> wrap(String text, int cols) {
    ArrayList<String> lines = new ArrayList<String>();
    String line;
    while (text.length() > cols) {
        int end = text.lastIndexOf(" ", cols); 
        if (end == -1) {
            end = cols;
        } else {
            end = end == 0 ? cols : end; // Ensure we don't have an empty line
        }
        line = text.substring(0,end).trim(); // Trim any leading or trailing spaces
        text = text.substring(end).trim(); // Trim the remaining text
        lines.add(line);
    }
    if (!text.isEmpty()) {
        lines.add(text.trim()); // Add any remaining text as the last line
    }
    return lines;
}

