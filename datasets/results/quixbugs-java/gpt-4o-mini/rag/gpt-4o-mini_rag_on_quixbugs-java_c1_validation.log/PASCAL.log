    ArrayList<Integer> init = new ArrayList<Integer>();
    init.add(1);
    rows.add(init);
    for (int r = 1; r < n; r++) {
        ArrayList<Integer> row = new ArrayList<Integer>();
        for (int c = 0; c <= r; c++) {
            int upleft, upright;
            if (c > 0) {
                upleft = rows.get(r - 1).get(c - 1);
            } else {
                upleft = 0;
            }
            if (c < r) {
                upright = rows.get(r - 1).get(c);
            } else {
                upright = 0;
            }
            row.add(upleft + upright);
        }
        rows.add(row);
    }
    return rows;
}

