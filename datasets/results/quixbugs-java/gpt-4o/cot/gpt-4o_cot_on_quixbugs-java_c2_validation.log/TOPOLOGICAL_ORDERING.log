                PATCH:
                public static ArrayList<Node> topological_ordering(List<Node> directedGraph) {
    ArrayList<Node> orderedNodes = new ArrayList<Node>();
    HashSet<Node> visitedNodes = new HashSet<Node>(); // Added to track visited nodes
    Queue<Node> queue = new LinkedList<Node>(); // Queue for processing nodes in order

    // Add nodes with no predecessors (in-degree 0) to the queue
    for (Node node : directedGraph) {
        if (node.getPredecessors().isEmpty()) {
            queue.add(node);
            visitedNodes.add(node); // Mark as visited
        }
    }

    // Process the queue
    while (!queue.isEmpty()) {
        Node currentNode = queue.poll();
        orderedNodes.add(currentNode);

        for (Node nextNode : currentNode.getSuccessors()) {
            // Check if all predecessors of nextNode are already visited
            boolean allPredecessorsVisited = true;
            for (Node predecessor : nextNode.getPredecessors()) {
                if (!visitedNodes.contains(predecessor)) {
                    allPredecessorsVisited = false;
                    break;
                }
            }

            if (allPredecessorsVisited && !visitedNodes.contains(nextNode)) {
                queue.add(nextNode);
                visitedNodes.add(nextNode); // Mark as visited
            }
        }
    }

    return orderedNodes;
}

