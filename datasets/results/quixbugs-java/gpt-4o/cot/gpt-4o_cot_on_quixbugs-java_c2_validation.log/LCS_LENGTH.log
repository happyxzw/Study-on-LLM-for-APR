                public static Integer lcs_length(String s, String t) {
    Map<Integer, Map<Integer, Integer>> dp = new HashMap<Integer, Map<Integer, Integer>>();
    for (int i = 0; i < s.length(); i++) {
        Map<Integer, Integer> initialize = new HashMap<Integer, Integer>();
        dp.put(i, initialize);
        for (int j = 0; j < t.length(); j++) {
            Map<Integer, Integer> internal_map = dp.get(i);
            internal_map.put(j, 0);
            dp.put(i, internal_map);
        }
    }
    for (int i = 0; i < s.length(); i++) {
        for (int j = 0; j < t.length(); j++) {
            if (s.charAt(i) == t.charAt(j)) {
                if (i > 0 && j > 0) { // Corrected condition to check valid indices for i-1 and j-1
                    Map<Integer, Integer> internal_map = dp.get(i);
                    int insert_value = dp.get(i - 1).get(j - 1) + 1; // Fixed to use (i-1, j-1)
                    internal_map.put(j, insert_value);
                    dp.put(i, internal_map);
                } else {
                    Map<Integer, Integer> internal_map = dp.get(i);
                    internal_map.put(j, 1);
                    dp.put(i, internal_map);
                }
            } else {
                if (i > 0 && j > 0) { // Handle non-matching case to propagate max value
                    Map<Integer, Integer> internal_map = dp.get(i);
                    int max_value = Math.max(dp.get(i - 1).get(j), dp.get(i).get(j - 1));
                    internal_map.put(j, max_value);
                    dp.put(i, internal_map);
                } else if (i > 0) {
                    Map<Integer, Integer> internal_map = dp.get(i);
                    int max_value = dp.get(i - 1).get(j);
                    internal_map.put(j, max_value);
                    dp.put(i, internal_map);
                } else if (j > 0) {
                    Map<Integer, Integer> internal_map = dp.get(i);
                    int max_value = dp.get(i).get(j - 1);
                    internal_map.put(j, max_value);
                    dp.put(i, internal_map);
                }
            }
        }
    }
    if (!dp.isEmpty()) {
        return dp.get(s.length() - 1).get(t.length() - 1); // Directly return the result from last cell
    } else {
        return 0;
    }
}

