                public static String next_palindrome(int[] digit_list) {
    int high_mid = Math.floorDiv(digit_list.length, 2);
    int low_mid = Math.floorDiv(digit_list.length - 1, 2);
    while (high_mid < digit_list.length && low_mid >= 0) {
        if (digit_list[high_mid] == 9) {
            digit_list[high_mid] = 0;
            digit_list[low_mid] = 0;
            high_mid += 1;
            low_mid -= 1;
        } else {
            digit_list[high_mid] += 1;
            if (low_mid != high_mid) {
                digit_list[low_mid] = digit_list[high_mid]; // Correctly mirror the digits
            }
            return Arrays.toString(digit_list);
        }
    }
    ArrayList<Integer> otherwise = new ArrayList<Integer>();
    otherwise.add(1);
    otherwise.addAll(Collections.nCopies(digit_list.length - 1, 0)); // Ensure correct length
    otherwise.add(1);
    return otherwise.toString(); // Correctly return the palindrome as a string representation
}

