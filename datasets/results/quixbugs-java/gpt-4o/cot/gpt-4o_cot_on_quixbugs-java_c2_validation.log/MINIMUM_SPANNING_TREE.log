            groupByNode.put(vertex_v, new HashSet<>(Arrays.asList(vertex_v)));
        }
        if (groupByNode.get(vertex_u) != groupByNode.get(vertex_v)) {
            minSpanningTree.add(edge);
            Set<Node> groupU = groupByNode.get(vertex_u);
            Set<Node> groupV = groupByNode.get(vertex_v);

            // Merge smaller group into the larger group for efficiency
