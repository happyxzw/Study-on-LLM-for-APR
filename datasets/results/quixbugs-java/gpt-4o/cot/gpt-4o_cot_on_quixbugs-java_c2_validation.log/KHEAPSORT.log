                PATCH:
                public static ArrayList<Integer> kheapsort(ArrayList<Integer> arr, int k) {
    PriorityQueue<Integer> heap = new PriorityQueue<Integer>();
    for (Integer v : arr.subList(0, Math.min(k, arr.size()))) { // Ensure k does not exceed arr.size()
        heap.add(v);
    }
    ArrayList<Integer> output = new ArrayList<Integer>();
    for (int i = k; i < arr.size(); i++) { // Start from index k to process remaining elements
        heap.add(arr.get(i)); // Add next element from arr to the heap
        Integer popped = heap.poll();
        output.add(popped);
    }
    while (!heap.isEmpty()) { // Add remaining elements from the heap
        output.add(heap.poll());
    }
    return output;
}

