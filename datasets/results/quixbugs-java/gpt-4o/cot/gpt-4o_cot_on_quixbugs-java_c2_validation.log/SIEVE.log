                PATCH:
                public static ArrayList<Integer> sieve(Integer max) {
    ArrayList<Integer> primes = new ArrayList<Integer>();
    for (int n = 2; n < max + 1; n++) {
        boolean isPrime = true; // Initialize a flag to check primality
        for (int prime : primes) { // Check divisibility using previously found primes
            if (n % prime == 0) {
                isPrime = false;
                break; // Exit loop if divisible
            }
        }
        if (isPrime) { // If not divisible by any prime, it is a prime number
            primes.add(n);
        }
    }
    return primes;
}

