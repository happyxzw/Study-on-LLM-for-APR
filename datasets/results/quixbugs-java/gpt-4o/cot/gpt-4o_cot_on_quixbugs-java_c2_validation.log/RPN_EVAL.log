                PATCH:
                public static Double rpn_eval(ArrayList tokens) {
    Map<String, BinaryOperator<Double>> op = new HashMap<String, BinaryOperator<Double>>();
    op.put("+", (a, b) -> a + b);
    op.put("-", (a, b) -> a - b);
    op.put("*", (a, b) -> a * b);
    op.put("/", (a, b) -> a / b);
    Stack<Double> stack = new Stack<>(); // Specify Stack type as Double
    for (Object token : tokens) {
        if (token instanceof Double) { // Use 'instanceof' instead of 'Double.class.isInstance'
            stack.push((Double) token);
        } else {
            token = (String) token;
            Double b = stack.pop(); // Fix order of popping to account for RPN (b first)
            Double a = stack.pop();
            Double c = 0.0;
            BinaryOperator<Double> bin_op = op.get(token);
            if (bin_op != null) { // Check if operator is valid
                c = bin_op.apply(a, b);
            } else {
                throw new IllegalArgumentException("Invalid operator: " + token);
            }
            stack.push(c);
        }
    }
    return stack.pop();
}

