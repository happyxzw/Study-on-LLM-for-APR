                PATCH:
                public static ArrayList<Integer> get_factors(int n) {
    if (n <= 1) { // Fixed condition to handle edge case for n <= 1
        return new ArrayList<Integer>();
    }
    ArrayList<Integer> factors = new ArrayList<Integer>(); // Initialize the result list
    int max = (int)(Math.sqrt(n)) + 1;
    for (int i = 2; i < max; i++) {
        while (n % i == 0) { // Use a while loop to factorize completely
            factors.add(i);
            n /= i; // Divide n by i
        }
    }
    if (n > 1) { // If n is still greater than 1, it's a prime factor
        factors.add(n);
    }
    return factors;
}

