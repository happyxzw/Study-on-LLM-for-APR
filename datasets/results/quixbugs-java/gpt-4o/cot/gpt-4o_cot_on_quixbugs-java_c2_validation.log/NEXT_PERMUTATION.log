                PATCH:
                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    for (int i = perm.size() - 2; i != -1; i--) {
        if (perm.get(i) < perm.get(i + 1)) {
            for (int j = perm.size() - 1; j != i; j--) {
                if (perm.get(j) > perm.get(i)) { // Fixed: Changed condition from `<` to `>` to find the correct swap element
                    ArrayList<Integer> next_perm = new ArrayList<>(perm); // Fixed: Created a copy of the list to avoid modifying the original
                    int temp_j = perm.get(j);
                    int temp_i = perm.get(i);
                    next_perm.set(i, temp_j);
                    next_perm.set(j, temp_i);
                    ArrayList<Integer> reversed = new ArrayList<>();
                    for (int k = next_perm.size() - 1; k > i; k--) { // Fixed: Changed `k != i` to `k > i` for proper range
                        reversed.add(next_perm.get(k));
                    }
                    int q = i + 1;
                    for (Integer replace : reversed) {
                        next_perm.set(q, replace);
                        q++;
                    }
                    return next_perm;
                }
            }
        }
    }
    return new ArrayList<>();
}

