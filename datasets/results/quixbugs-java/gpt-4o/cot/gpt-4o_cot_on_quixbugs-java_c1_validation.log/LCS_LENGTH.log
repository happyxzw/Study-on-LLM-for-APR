                PATCH:
                public static Integer lcs_length(String s, String t) {
    Map<Integer, Map<Integer, Integer>> dp = new HashMap<>();

    // Initialize the DP table with 0 values.
    for (int i = 0; i <= s.length(); i++) { // Note: Using <= for length to handle base case properly.
        Map<Integer, Integer> initialize = new HashMap<>();
        for (int j = 0; j <= t.length(); j++) { // Note: Using <= for length to handle base case properly.
            initialize.put(j, 0);
        }
        dp.put(i, initialize);
    }

    // Fill the DP table based on LCS logic.
    for (int i = 1; i <= s.length(); i++) { // Start from 1 to handle base case (i-1 index).
        for (int j = 1; j <= t.length(); j++) { // Start from 1 to handle base case (j-1 index).
            if (s.charAt(i - 1) == t.charAt(j - 1)) { // Compare chars at (i-1) and (j-1) for LCS.
                dp.get(i).put(j, dp.get(i - 1).get(j - 1) + 1);
            } else {
                dp.get(i).put(j, Math.max(dp.get(i - 1).get(j), dp.get(i).get(j - 1)));
            }
        }
    }

    // The length of LCS is stored in dp[s.length()][t.length()].
    return dp.get(s.length()).get(t.length());
}

