                int max_value = Math.max(dp.get(i - 1).get(j), dp.get(i).get(j - 1)); // Get max of top or left cell
                internal_map.put(j, max_value);
                dp.put(i, internal_map);
            }
        }
    }
    return dp.get(s.length()).get(t.length()); // Return the bottom-right value in the DP table
}

