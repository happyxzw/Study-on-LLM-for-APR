                PATCH:
                public static ArrayList<Integer> kheapsort(ArrayList<Integer> arr, int k) {
    PriorityQueue<Integer> heap = new PriorityQueue<Integer>();
    // Add the first k elements to the heap
    for (Integer v : arr.subList(0, k)) {
        heap.add(v);
    }
    ArrayList<Integer> output = new ArrayList<Integer>();
    // Process elements from index k to the end of the array
    for (int i = k; i < arr.size(); i++) {
        heap.add(arr.get(i)); // Add the next element to the heap
        output.add(heap.poll()); // Remove and add the smallest element to the output
    }
    // Add remaining elements from the heap to the output
    while (!heap.isEmpty()) {
        output.add(heap.poll());
    }
    return output;
}

