                PATCH:
                public static ArrayList<Integer> get_factors(int n) {
    if (n <= 1) { // Fix: Handle edge case for n <= 1 to avoid invalid input issues.
        return new ArrayList<Integer>();
    }
    ArrayList<Integer> factors = new ArrayList<Integer>(); // Fix: Initialize an ArrayList to collect all factors.
    int max = (int)(Math.sqrt(n) + 1.0);
    for (int i = 2; i < max; i++) {
        while (n % i == 0) { // Fix: Use a loop to account for repeated factors (e.g., 4 = 2 * 2).
            factors.add(i); // Collect the factor.
            n /= i; // Divide n to reduce it for further processing.
        }
    }
    if (n > 1) { // Fix: If n is still greater than 1, it is a prime factor itself.
        factors.add(n);
    }
    return factors;
}

