                PATCH:
                public static ArrayList<Integer> get_factors(int n) {
    if (n <= 1) { // Changed from n == 1 to n <= 1 to handle edge cases like n = 0 or negative numbers.
        return new ArrayList<Integer>();
    }
    ArrayList<Integer> factors = new ArrayList<Integer>();
    int max = (int)(Math.sqrt(n) + 1.0);
    for (int i = 2; i < max; i++) {
        while (n % i == 0) { // Changed if to while to handle multiple factors of the same number, e.g., n = 8.
            factors.add(i);
            n /= i;
        }
    }
    if (n > 1) { // If n is still greater than 1, it is a prime factor.
        factors.add(n);
    }
    return factors;
}

