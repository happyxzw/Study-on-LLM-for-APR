                PATCH:
                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    for (int i = perm.size() - 2; i >= 0; i--) { // Find the first decreasing element from the right
        if (perm.get(i) < perm.get(i + 1)) {
            for (int j = perm.size() - 1; j > i; j--) { // Find the next larger element to swap with
                if (perm.get(j) > perm.get(i)) {
                    ArrayList<Integer> next_perm = new ArrayList<>(perm); // Create a new ArrayList copy to avoid modifying the original
                    int temp_j = perm.get(j);
                    int temp_i = perm.get(i);
                    next_perm.set(i, temp_j); // Swap elements at i and j
                    next_perm.set(j, temp_i);

                    // Reverse the portion of the array from i+1 to the end
                    ArrayList<Integer> reversed = new ArrayList<>();
                    for (int k = next_perm.size() - 1; k > i; k--) {
                        reversed.add(next_perm.get(k));
                    }
                    int q = i + 1;
                    for (Integer replace : reversed) {
                        next_perm.set(q, replace);
                        q++;
                    }
                    return next_perm;
                }
            }
        }
    }
    return new ArrayList<>(); // If no next permutation exists, return an empty list
}

