                public static Map<String, Integer> shortest_paths(String source, Map<List<String>, Integer> weight_by_edge) {
    Map<String, Integer> weight_by_node = new HashMap<String, Integer>();

    // Initialize the weight of each node to infinity.
    for (List<String> edge : weight_by_edge.keySet()) {
        weight_by_node.put(edge.get(1), INF);
        weight_by_node.put(edge.get(0), INF);
    }

    // Set the source node's weight to 0.
    weight_by_node.put(source, 0);

    // Perform the relaxation process (Bellman-Ford algorithm).
    for (int i = 0; i < weight_by_node.size() - 1; i++) { // Loop should run |V| - 1 times.
        for (List<String> edge : weight_by_edge.keySet()) {
            String u = edge.get(0);
            String v = edge.get(1);
            int edge_weight = weight_by_edge.get(edge);

            // Relax the edge if a shorter path is found.
            if (weight_by_node.get(u) != INF && weight_by_node.get(u) + edge_weight < weight_by_node.get(v)) {
                weight_by_node.put(v, weight_by_node.get(u) + edge_weight);
            }
        }
    }

    return weight_by_node;
}

