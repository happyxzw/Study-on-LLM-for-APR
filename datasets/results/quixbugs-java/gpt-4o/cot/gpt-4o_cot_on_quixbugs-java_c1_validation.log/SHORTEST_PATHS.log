                public static Map<String, Integer> shortest_paths(String source, Map<List<String>, Integer> weight_by_edge) {
    Map<String, Integer> weight_by_node = new HashMap<String, Integer>();

    // Initialize all node weights to INF
    for (List<String> edge : weight_by_edge.keySet()) {
        weight_by_node.put(edge.get(1), Integer.MAX_VALUE);
        weight_by_node.put(edge.get(0), Integer.MAX_VALUE);
    }

    // Set the source node weight to 0
    weight_by_node.put(source, 0);

    // Relax edges repeatedly
    for (int i = 0; i < weight_by_node.size() - 1; i++) { // Corrected loop boundary to size - 1
        for (List<String> edge : weight_by_edge.keySet()) {
            String u = edge.get(0);
            String v = edge.get(1);
            int weight = weight_by_edge.get(edge);

            // Relax the edge (u -> v)
            if (weight_by_node.get(u) != Integer.MAX_VALUE && weight_by_node.get(u) + weight < weight_by_node.get(v)) {
                weight_by_node.put(v, weight_by_node.get(u) + weight);
            }
        }
    }

    return weight_by_node;
}

