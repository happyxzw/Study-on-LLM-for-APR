                PATCH:
                public static Set<WeightedEdge> minimum_spanning_tree(List<WeightedEdge> weightedEdges) {
    Map<Node, Set<Node>> groupByNode = new HashMap<>();
    Set<WeightedEdge> minSpanningTree = new HashSet<>();
    Collections.sort(weightedEdges);

    for (WeightedEdge edge : weightedEdges) {
        Node vertex_u = edge.node1;
        Node vertex_v = edge.node2;

        // Initialize groups for nodes if they don't exist
        groupByNode.putIfAbsent(vertex_u, new HashSet<>(Arrays.asList(vertex_u)));
        groupByNode.putIfAbsent(vertex_v, new HashSet<>(Arrays.asList(vertex_v)));

        // Check if both nodes belong to the same group
        if (groupByNode.get(vertex_u) != groupByNode.get(vertex_v)) {
            minSpanningTree.add(edge);

            // Merge the groups
            Set<Node> groupU = groupByNode.get(vertex_u);
            Set<Node> groupV = groupByNode.get(vertex_v);
            groupU.addAll(groupV);

            // Update the group mapping for all nodes in groupV
            for (Node node : groupV) {
                groupByNode.put(node, groupU);
            }
        }
    }
    return minSpanningTree;
}

