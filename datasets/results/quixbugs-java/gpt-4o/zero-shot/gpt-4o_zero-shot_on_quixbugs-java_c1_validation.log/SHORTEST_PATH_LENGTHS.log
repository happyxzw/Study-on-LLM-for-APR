                int through_k_length = (length_by_path.get(Arrays.asList(i, k)) == Integer.MAX_VALUE || length_by_path.get(Arrays.asList(k, j)) == Integer.MAX_VALUE) 
                                       ? Integer.MAX_VALUE 
                                       : length_by_path.get(Arrays.asList(i, k)) + length_by_path.get(Arrays.asList(k, j));
                length_by_path.put(Arrays.asList(i, j), Math.min(current_length, through_k_length));
            }
        }
    }
    return length_by_path;
