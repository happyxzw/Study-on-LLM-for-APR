                public static ArrayList<ArrayList<Integer>> pascal(int n) {
    ArrayList<ArrayList<Integer>> rows = new ArrayList<ArrayList<Integer>>();
    if (n <= 0) return rows;
    ArrayList<Integer> init = new ArrayList<Integer>();
    init.add(1);
