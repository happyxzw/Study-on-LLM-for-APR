                PATCH:
                public static int lis(int[] arr) {
    Map<Integer, Integer> ends = new HashMap<>();
    int longest = 0;

    for (int i = 0; i < arr.length; i++) {
        int val = arr[i];
        int left = 1, right = longest;
        while (left <= right) {
            int mid = (left + right) / 2;
            if (arr[ends.get(mid)] < val) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        int length = left;
        ends.put(length, i);
        if (length > longest) {
            longest = length;
        }
    }

    return longest;
}

