                PATCH:
                public static ArrayList<Integer> get_factors(int n) {
    ArrayList<Integer> factors = new ArrayList<>();
    if (n < 2) {
        return factors;
    }
    int max = (int) Math.sqrt(n) + 1;
    for (int i = 2; i <= max; i++) {
        while (n % i == 0) {
            factors.add(i);
            n /= i;
        }
    }
    if (n > 1) {
        factors.add(n);
    }
    return factors;
}

