                PATCH:
                public static ArrayList<Integer> next_permutation(ArrayList<Integer> perm) {
    for (int i = perm.size() - 2; i >= 0; i--) {
        if (perm.get(i) < perm.get(i + 1)) {
            for (int j = perm.size() - 1; j > i; j--) {
                if (perm.get(j) > perm.get(i)) {
                    ArrayList<Integer> next_perm = new ArrayList<>(perm);
                    int temp = next_perm.get(i);
                    next_perm.set(i, next_perm.get(j));
                    next_perm.set(j, temp);
                    ArrayList<Integer> suffix = new ArrayList<>(next_perm.subList(i + 1, next_perm.size()));
                    Collections.reverse(suffix);
                    for (int k = 0; k < suffix.size(); k++) {
                        next_perm.set(i + 1 + k, suffix.get(k));
                    }
                    return next_perm;
                }
            }
        }
    }
    return new ArrayList<>();
}

