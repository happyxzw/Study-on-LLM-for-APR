                PATCH:
                public static boolean breadth_first_search(Node startnode, Node goalnode) {
    Deque<Node> queue = new ArrayDeque<>();
    Set<Node> nodesvisited = new HashSet<>(); // Initialize nodesvisited properly
    queue.addLast(startnode);
    nodesvisited.add(startnode);
    while (!queue.isEmpty()) { // Check if the queue is not empty
        Node node = queue.removeFirst();
        if (node == goalnode) {
            return true;
        } else {
            for (Node successor_node : node.getSuccessors()) {
                if (!nodesvisited.contains(successor_node)) {
                    queue.addLast(successor_node); // Add to the end of the queue (breadth-first)
                    nodesvisited.add(successor_node);
                }
            }
        }
    }
    return false; // Return false if the goalnode is not found
}

