                public static String next_palindrome(int[] digit_list) {
    int high_mid = Math.floorDiv(digit_list.length, 2);
    int low_mid = Math.floorDiv(digit_list.length - 1, 2);
    boolean all_nines = true;

    for (int digit : digit_list) {
        if (digit != 9) {
            all_nines = false;
            break;
        }
    }

    if (all_nines) {
        ArrayList<Integer> otherwise = new ArrayList<>();
        otherwise.add(1);
        otherwise.addAll(Collections.nCopies(digit_list.length - 1, 0));
        otherwise.add(1);
        return otherwise.toString();
    }

    while (high_mid < digit_list.length && low_mid >= 0) {
        if (digit_list[high_mid] > digit_list[low_mid]) {
            break;
        }
        high_mid++;
        low_mid--;
    }

    high_mid = Math.floorDiv(digit_list.length, 2);
