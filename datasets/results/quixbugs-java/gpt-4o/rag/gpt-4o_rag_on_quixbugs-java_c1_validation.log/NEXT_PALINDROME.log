                PATCH:
                public static String next_palindrome(int[] digit_list) {
    int high_mid = Math.floorDiv(digit_list.length, 2);
    int low_mid = Math.floorDiv(digit_list.length - 1, 2);

    while (low_mid >= 0) {
        if (digit_list[low_mid] < 9) {
            digit_list[low_mid]++;
            if (low_mid != high_mid) {
                digit_list[high_mid]++;
            }
            for (int i = low_mid + 1, j = high_mid - 1; i < digit_list.length && j >= 0; i++, j--) {
                digit_list[i] = digit_list[j];
            }
            return Arrays.toString(digit_list);
        } else {
            digit_list[low_mid] = 0;
            digit_list[high_mid] = 0;
        }
        low_mid--;
        high_mid++;
    }

    int[] result = new int[digit_list.length + 1];
    result[0] = 1;
    result[result.length - 1] = 1;
    return Arrays.toString(result);
}

