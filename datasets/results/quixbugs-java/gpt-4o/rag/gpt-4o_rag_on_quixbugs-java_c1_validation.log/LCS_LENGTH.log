        dp.put(i, new HashMap<>());
        for (int j = 0; j <= t.length(); j++) {
            dp.get(i).put(j, 0);
        }
    }

    for (int i = 1; i <= s.length(); i++) {
        for (int j = 1; j <= t.length(); j++) {
