                PATCH:
                public static String to_base(int num, int b) {
    if (b < 2 || b > 36) {
        throw new IllegalArgumentException("Base b must be in the range 2 to 36");
    }
    if (num == 0) {
        return "0";
    }
    String result = "";
    String alphabet = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    while (num > 0) {
        int i = num % b;
        num = num / b;
        result = alphabet.charAt(i) + result;
    }
    return result;
}

