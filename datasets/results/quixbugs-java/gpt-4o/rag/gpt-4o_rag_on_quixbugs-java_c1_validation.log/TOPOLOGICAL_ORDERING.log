            if (!visitedNodes.contains(nextNode) && orderedNodes.containsAll(nextNode.getPredecessors())) {
                orderedNodes.add(nextNode);
                visitedNodes.add(nextNode);
            }
        }
        index++;
    }

    return orderedNodes;
