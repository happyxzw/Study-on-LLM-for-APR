        for (List<String> edge : weight_by_edge.keySet()) {
            String from = edge.get(0);
            String to = edge.get(1);
            if (weight_by_node.get(from) != Integer.MAX_VALUE) {
                int new_weight = weight_by_node.get(from) + weight_by_edge.get(edge);
                if (new_weight < weight_by_node.get(to)) {
                    weight_by_node.put(to, new_weight);
                }
            }
        }
    }
    return weight_by_node;
}

