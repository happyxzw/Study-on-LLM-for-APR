                PATCH:
                public static Integer kth(ArrayList<Integer> arr, int k) {
    if (arr == null || arr.size() == 0 || k < 0 || k >= arr.size()) {
        throw new IllegalArgumentException("Invalid input");
    }
    int pivot = arr.get(0);
    ArrayList<Integer> below = new ArrayList<>();
    ArrayList<Integer> above = new ArrayList<>();
    ArrayList<Integer> equal = new ArrayList<>();

    for (Integer x : arr) {
        if (x < pivot) {
            below.add(x);
        } else if (x > pivot) {
            above.add(x);
        } else {
            equal.add(x);
        }
    }

    int numLess = below.size();
    int numEqual = equal.size();

    if (k < numLess) {
        return kth(below, k);
    } else if (k < numLess + numEqual) {
        return pivot;
    } else {
        return kth(above, k - numLess - numEqual);
    }
}

