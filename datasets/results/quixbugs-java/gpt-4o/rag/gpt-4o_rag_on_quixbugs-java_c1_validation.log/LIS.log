                PATCH:
                public static int lis(int[] arr) {
    Map<Integer, Integer> ends = new HashMap<>();
    int longest = 0;
    int i = 0;
    for (int val : arr) {
        List<Integer> prefixLengths = new ArrayList<>();
        for (int j = 1; j <= longest; j++) {
            if (arr[ends.get(j)] < val) {
                prefixLengths.add(j);
            }
        }
        int length = !prefixLengths.isEmpty() ? Collections.max(prefixLengths) : 0;
        if (length == longest || !ends.containsKey(length + 1) || val < arr[ends.get(length + 1)]) {
            ends.put(length + 1, i);
            longest = Math.max(longest, length + 1);
        }
        i++;
    }
    return longest;
}

