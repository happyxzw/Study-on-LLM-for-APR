                PATCH:
                public static int lis(int[] arr) {
    Map<Integer, Integer> ends = new HashMap<>();
    int longest = 0;

    for (int i = 0; i < arr.length; i++) {
        int val = arr[i];
        int low = 1, high = longest;

        while (low <= high) {
            int mid = (low + high) / 2;
            if (arr[ends.get(mid)] < val) {
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }

        int length = low;

        if (length > longest) {
            longest = length;
        }

        ends.put(length, i);

        if (length > 1 && arr[ends.get(length - 1)] >= val) {
            ends.put(length, ends.get(length - 1));
        }
    }
    return longest;
}

